<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Bucket - Import ISO Wizard"
    Width="800"
    Height="600"
    WindowStartupLocation="CenterScreen"
    Background="#F9F9F9"
    ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Title -->
            <RowDefinition Height="*" /> <!-- Main content -->
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0">
            <TextBlock Text="Import and Select Your Image" Margin="10" FontWeight="Bold" FontSize="16"/>
        </Grid>

        <!-- Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <!-- Sidebar -->
                <ColumnDefinition Width="*" /> <!-- Main content -->
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <StackPanel Grid.Column="0" Margin="10" Width="150" Background="#F0F0F0">
                <TextBlock Text="Data Source" Margin="10,15" FontWeight="SemiBold" />
                <TextBlock Text="Select index" Margin="10,15" />
                <TextBlock Text="Summary" Margin="10,15" />
                <TextBlock Text="Progress" Margin="10,15" />
                <TextBlock Text="Completion" Margin="10,15" />
            </StackPanel>

            <!-- Main Content Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" /> <!-- Main Frame -->
                    <RowDefinition Height="Auto" /> <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Main Frame -->
                <Frame
                x:Name="MainWindow_ImportISO_MainFrame"
                Grid.Row="0"
                NavigationUIVisibility="Hidden"
                Background="#F9F9F9" />

                <!-- Footer -->
                <StackPanel
                Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,10,20,20">
                    <Button x:Name="MainWindow_ImportISO_PreviousButton" Content="Previous" Margin="5,0" Padding="10,5" Width="100" />
                    <Button x:Name="MainWindow_ImportISO_NextButton" Content="Next" Margin="5,0" Padding="10,5" Width="100" Background="#0078D7" Foreground="White" FontWeight="Bold" />
                    <Button x:Name="MainWindow_ImportISO_SummaryButton" Content="Summary" Margin="5,0" Padding="10,5" Width="100" />
                    <Button x:Name="MainWindow_ImportISO_CancelButton" Content="Cancel" Margin="5,0" Padding="10,5" Width="100" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>