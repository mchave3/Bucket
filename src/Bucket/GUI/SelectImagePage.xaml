<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Class="Bucket.GUI.SelectImagePage"
    Title="Home"
    Background="#F9F9F9">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock 
            Grid.Row="0"
            Text="Import and Customize Your Image"
            FontSize="28"
            FontWeight="SemiBold"
            Margin="0,0,0,20" />

        <!-- Main content -->
        <StackPanel Grid.Row="1">
            <!-- Import Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20" HorizontalAlignment="Center">
                <Button x:Name="SelectImage_ImportISOButton" Content="Import ISO" Width="120" Padding="15,8" Margin="0,0,20,0" />
                <Button x:Name="SelectImage_ImportWIMButton" Content="Import WIM" Width="120" Padding="15,8" />
            </StackPanel>

            <!-- WIM Images Table -->
            <TextBlock Text="Available Images" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />

            <!-- Select All Option and Delete Button -->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="SelectImage_SelectAllCheckbox" 
                          Content="Select All Images"
                          Grid.Column="0"
                          VerticalAlignment="Center" />

                <Button x:Name="SelectImage_RefreshButton" 
                        Content="Refresh"
                        Grid.Column="1"
                        Padding="10,5"
                        Width="100"
                        Margin="0,0,10,0" />

                <Button x:Name="SelectImage_DeleteButton" 
                        Content="Delete Selected"
                        Grid.Column="2"
                        Padding="10,5"
                        Width="120" />
            </Grid>

            <!-- DataGrid for displaying images -->
            <DataGrid x:Name="SelectImage_ImagesDataGrid" 
                        AutoGenerateColumns="False" 
                        HeadersVisibility="Column"
                        GridLinesVisibility="Horizontal"
                        Background="White"
                        BorderThickness="1"
                        BorderBrush="#DDDDDD"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        SelectionMode="Extended"
                        SelectionUnit="FullRow"
                        MaxHeight="400"
                        Margin="0,10,0,0">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Select" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="File Path" Binding="{Binding Path}" Width="3*" />
                    <DataGridTextColumn Header="Version (Index 1)" Binding="{Binding Version}" Width="1*" />
                    <DataGridTextColumn Header="Size (MB)" Binding="{Binding Size}" Width="80" />
                    <DataGridTextColumn Header="Import Date" Binding="{Binding ImportDate}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Image Details Section -->
            <Border BorderBrush="#DDDDDD" 
                    BorderThickness="1" 
                    Margin="0,20,0,0" 
                    Padding="15" 
                    Background="#F5F5F5">
                <StackPanel>
                    <TextBlock Text="Image Details" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,10" />

                    <DataGrid x:Name="SelectImage_DetailsDataGrid" 
                              AutoGenerateColumns="False" 
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="White"
                              BorderThickness="1"
                              BorderBrush="#DDDDDD"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              MaxHeight="250">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Index" Binding="{Binding Index}" Width="80" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Architecture" Binding="{Binding Architecture}" Width="120" />
                            <DataGridTextColumn Header="Edition" Binding="{Binding Edition}" Width="120" />
                            <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="120" />
                            <DataGridTextColumn Header="Languages" Binding="{Binding Languages}" Width="120" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="200" />
                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Footer -->
        <StackPanel 
            Grid.Row="2"
            Orientation="Horizontal" 
            HorizontalAlignment="Right"
            Margin="0,20,20,0">
            <Button x:Name="SelectImage_SkipButton" Content="Skip" Margin="5,0" Padding="10,5" Width="100" />
            <Button x:Name="SelectImage_PreviousButton" Content="Previous" Margin="5,0" Padding="10,5" Width="100" />
            <Button x:Name="SelectImage_NextButton" Content="Next" Margin="5,0" Padding="10,5" Width="100" Background="#0078D7" Foreground="White" FontWeight="Bold" />
            <Button x:Name="SelectImage_SummaryButton" Content="Summary" Margin="5,0" Padding="10,5" Width="100" />
        </StackPanel>
    </Grid>
</Page>