<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Class="Bucket.GUI.DriversPage"
    Title="Pilotes"
    Background="{ui:ThemeResource ApplicationBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <TextBlock 
            Grid.Row="0"
            Text="Gestion des pilotes"
            FontSize="28"
            FontWeight="SemiBold"
            Margin="0,0,0,20" />

        <!-- Info sur l'image actuelle -->
        <ui:Card
            Grid.Row="1"
            Margin="0,0,0,20"
            Icon="{ui:SymbolIcon DiskImage24}">
            <ui:CardControl.Header>
                <Grid>
                    <TextBlock Text="Image actuellement montée" FontWeight="Medium" />
                    <TextBlock Text="{Binding ImageMountStatus}" HorizontalAlignment="Right" />
                </Grid>
            </ui:CardControl.Header>
            <TextBlock 
                Text="{Binding CurrentImageInfo}"
                Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
        </ui:Card>

        <!-- Contenu principal -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Actions d'ajout de pilotes -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox 
                    Grid.Column="0"
                    PlaceholderText="Chemin vers le dossier ou fichier de pilote (.inf, .cab, dossier)"
                    Name="TxtDriverPath"
                    IsReadOnly="True" />
                
                <ui:Button 
                    Grid.Column="1"
                    Content="Parcourir"
                    Icon="{ui:SymbolIcon Folder24}"
                    Appearance="Secondary"
                    Margin="10,0,0,0"
                    Name="BtnBrowseDriver" />
                    
                <ui:Button 
                    Grid.Column="2"
                    Content="Ajouter"
                    Icon="{ui:SymbolIcon Add24}"
                    Appearance="Primary"
                    Margin="10,0,0,0"
                    Name="BtnAddDriver" />
            </Grid>
            
            <!-- Options d'ajout -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Pilotes présents dans l'image -->
                <ui:Card Grid.Column="0" Margin="0,0,10,0">
                    <ui:CardControl.Header>
                        <Grid>
                            <TextBlock Text="Pilotes actuellement dans l'image" FontWeight="Medium" />
                            <ui:Badge
                                Appearance="Secondary"
                                HorizontalAlignment="Right"
                                Content="{Binding InstalledDriversCount}" />
                        </Grid>
                    </ui:CardControl.Header>

                    <!-- Liste des pilotes installés -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ui:TextBox 
                            Grid.Row="0"
                            PlaceholderText="Filtrer les pilotes"
                            Icon="{ui:SymbolIcon Search24}"
                            Name="TxtFilterInstalledDrivers"
                            Margin="0,0,0,10" />

                        <DataGrid 
                            Grid.Row="1"
                            Name="DgInstalledDrivers"
                            AutoGenerateColumns="False"
                            IsReadOnly="True"
                            SelectionMode="Extended"
                            BorderThickness="1"
                            Height="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="90" />
                                <DataGridTextColumn Header="Fabricant" Binding="{Binding Manufacturer}" Width="120" />
                                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="100" />
                                <DataGridTemplateColumn Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:Button
                                                Icon="{ui:SymbolIcon Delete24}"
                                                Appearance="Danger"
                                                Name="BtnDeleteDriver" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </ui:Card>

                <!-- Pilotes en attente d'ajout -->
                <ui:Card Grid.Column="1" Margin="10,0,0,0">
                    <ui:CardControl.Header>
                        <Grid>
                            <TextBlock Text="Pilotes en attente d'ajout" FontWeight="Medium" />
                            <ui:Badge
                                Appearance="Primary"
                                HorizontalAlignment="Right"
                                Content="{Binding PendingDriversCount}" />
                        </Grid>
                    </ui:CardControl.Header>

                    <!-- Liste des pilotes en attente -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListBox 
                            Grid.Row="0"
                            Name="LbPendingDrivers"
                            Height="300">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="Medium" />
                                            <TextBlock Text="{Binding Path}" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        
                                        <ui:Button
                                            Grid.Column="1"
                                            Icon="{ui:SymbolIcon Delete24}"
                                            Appearance="Danger"
                                            Name="BtnDeletePendingDriver" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ui:Button 
                            Grid.Row="1"
                            Content="Vider la liste"
                            Icon="{ui:SymbolIcon Delete24}"
                            Appearance="Danger"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0"
                            Name="BtnClearPendingDrivers" />
                    </Grid>
                </ui:Card>
            </Grid>
            
            <!-- Options avancées -->
            <ui:CardExpander 
                Grid.Row="2"
                Icon="{ui:SymbolIcon Wrench24}" 
                Header="Options avancées"
                Margin="0,0,0,20">
                <StackPanel Spacing="8">
                    <ui:ToggleSwitch Content="Forcer la signature numérique" 
                                   Name="ToggleForceSignature" 
                                   IsChecked="True" />
                    <ui:ToggleSwitch Content="Recursive (analyse des sous-dossiers)" 
                                   Name="ToggleRecursive" 
                                   IsChecked="True" />
                    <ui:ComboBox 
                        PlaceholderText="Architecture"
                        Margin="0,8,0,0"
                        Name="CmbArchitecture">
                        <ComboBoxItem Content="x86" />
                        <ComboBoxItem Content="x64" IsSelected="True" />
                        <ComboBoxItem Content="arm" />
                        <ComboBoxItem Content="arm64" />
                    </ui:ComboBox>
                </StackPanel>
            </ui:CardExpander>
            
            <!-- Boutons d'action -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <ui:InfoBar
                    Grid.Column="0"
                    Title="Pilotes en attente"
                    Message="{Binding PendingDriversCount, StringFormat='{}{0} pilote(s) prêt(s) à être ajouté(s)'}"
                    Severity="Information"
                    IsOpen="True"
                    IsClosable="False" />
                
                <ui:Button 
                    Grid.Column="1"
                    Content="Injecter les pilotes"
                    Icon="{ui:SymbolIcon SendFill24}"
                    Appearance="Success"
                    Name="BtnInjectDrivers" />
            </Grid>
        </Grid>
    </Grid>
</Page>