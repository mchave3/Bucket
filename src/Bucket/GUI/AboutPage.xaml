<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Class="Bucket.GUI.AboutPage"
    Title="About"
    Background="#F9F9F9">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock 
            Grid.Row="0"
            Text="About Bucket"
            FontSize="28"
            FontWeight="SemiBold"
            Margin="0,0,0,20" />

        <!-- Main content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="0,0,0,20">
                <!-- Logo and description -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,30">
                    <TextBlock 
                        Text="Bucket" 
                        FontSize="32" 
                        FontWeight="SemiBold" 
                        HorizontalAlignment="Center" />
                        
                    <TextBlock 
                        Text="{Binding AppVersion, StringFormat='Version {0}'}" 
                        FontSize="16" 
                        HorizontalAlignment="Center" 
                        Opacity="0.8"
                        Margin="0,5,0,0" />
                </StackPanel>
                
                <!-- Description -->
                <Border 
                    Background="White" 
                    CornerRadius="8" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    Margin="0,0,0,20" 
                    Padding="20">
                    <TextBlock 
                        Text="Bucket is a powerful tool designed to customize, optimize and deploy Windows images. Create fully customized Windows installations in just a few clicks."
                        TextWrapping="Wrap" 
                        TextAlignment="Center" 
                        LineHeight="24" />
                </Border>
                
                <!-- Author -->
                <Border 
                    Background="White" 
                    CornerRadius="8" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    Margin="0,0,0,20" 
                    Padding="20">
                    <StackPanel>
                        <TextBlock 
                            Text="Author" 
                            FontSize="18" 
                            FontWeight="SemiBold" 
                            Margin="0,0,0,15" />
                        
                        <StackPanel>
                            <TextBlock Text="{Binding Author}" FontWeight="SemiBold" />
                            <TextBlock Margin="0,8,0,0">
                                <Hyperlink NavigateUri="https://github.com/mchave3">
                                    GitHub: @mchave3
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Legal Information -->
                <Border 
                    Background="White" 
                    CornerRadius="8" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    Margin="0,0,0,20" 
                    Padding="20">
                    <StackPanel>
                        <TextBlock 
                            Text="Legal Information" 
                            FontSize="18" 
                            FontWeight="SemiBold" 
                            Margin="0,0,0,15" />
                        
                        <StackPanel>
                            <TextBlock Text="{Binding License, StringFormat='License: {0}'}" FontWeight="SemiBold" />
                            <TextBlock 
                                Text="Copyright © 2025 Mickaël CHAVE. All rights reserved."
                                TextWrapping="Wrap"
                                Margin="0,8,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- System Information -->
                <Border 
                    Background="White" 
                    CornerRadius="8" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    Margin="0,0,0,20" 
                    Padding="20">
                    <StackPanel>
                        <TextBlock 
                            Text="System Information" 
                            FontSize="18" 
                            FontWeight="SemiBold" 
                            Margin="0,0,0,15" />
                        
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="PowerShell Version:" />
                                <TextBlock Grid.Column="1" Text="{Binding PowerShellVersion}" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="OS Version:" />
                                <TextBlock Grid.Column="1" Text="{Binding OSVersion}" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text=".NET Version:" />
                                <TextBlock Grid.Column="1" Text="{Binding DotNetVersion}" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Build Date:" />
                                <TextBlock Grid.Column="1" Text="{Binding BuildDate}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Libraries Used -->
                <Border 
                    Background="White" 
                    CornerRadius="8" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    Margin="0,0,0,20" 
                    Padding="20">
                    <StackPanel>
                        <TextBlock 
                            Text="Libraries Used" 
                            FontSize="18" 
                            FontWeight="SemiBold" 
                            Margin="0,0,0,15" />
                        
                        <StackPanel>
                            <!-- DataGrid pour les modules -->
                            <DataGrid Name="About_ModulesDataGrid" 
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      BorderThickness="1"
                                      BorderBrush="#E0E0E0"
                                      Margin="0,5,0,10"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      Background="Transparent"
                                      MaxHeight="150">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Module" Binding="{Binding About_Modules_Name}" Width="*" />
                                    <DataGridTextColumn Header="Version" Binding="{Binding About_Modules_Version}" Width="Auto" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding About_Modules_Status}" Width="Auto" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Links -->
                <Border 
                    Background="White" 
                    CornerRadius="8" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    Margin="0,0,0,20" 
                    Padding="20">
                    <StackPanel>
                        <TextBlock 
                            Text="Links" 
                            FontSize="18" 
                            FontWeight="SemiBold" 
                            Margin="0,0,0,15" />
                        
                        <StackPanel>
                            <Button 
                                Content="Website"
                                Name="About_WebsiteButton"
                                Margin="0,0,0,16"
                                Padding="12,8"
                                Height="40"
                                Background="#2979FF"
                                Foreground="White"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Stretch">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            
                            <Button 
                                Content="GitHub Repository"
                                Name="About_GitHubButton"
                                Margin="0,0,0,16"
                                Padding="12,8"
                                Height="40"
                                Background="#2979FF"
                                Foreground="White"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Stretch">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            
                            <Button 
                                Content="Report an Issue"
                                Name="About_ReportIssueButton"
                                Margin="0,0,0,16"
                                Padding="12,8"
                                Height="40"
                                Background="#F5F5F5"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Stretch">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            
                            <Button 
                                Content="Check for Updates"
                                Name="About_CheckUpdateButton"
                                Margin="0,0,0,16"
                                Padding="12,8"
                                Height="40"
                                Background="#F5F5F5"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Stretch">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            
                            <Button 
                                Content="View License"
                                Name="About_LicenseButton"
                                Padding="12,8"
                                Height="40"
                                Background="#F5F5F5"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Stretch">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Acknowledgments -->
                <Border 
                    Background="White" 
                    CornerRadius="8" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    Padding="20">
                    <StackPanel>
                        <TextBlock 
                            Text="Acknowledgments"
                            FontWeight="SemiBold"
                            FontSize="18"
                            Margin="0,0,0,15" />
                        <TextBlock 
                            Text="Thanks to all contributors and the community for their support in the development of this tool."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                
                <!-- Footer -->
                <TextBlock 
                    Text="Developed by Mickaël CHAVE - © 2025" 
                    FontSize="12" 
                    Opacity="0.6" 
                    HorizontalAlignment="Center" 
                    Margin="0,20,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
