<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Class="Bucket.GUI.HomePage"
    Title="Accueil"
    Background="#F9F9F9">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <TextBlock 
            Grid.Row="0"
            Text="Bienvenue dans Bucket"
            FontSize="28"
            FontWeight="SemiBold"
            Margin="0,0,0,20" />

        <!-- Contenu principal -->
        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- Logo et description -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,30">
                    <Image 
                        Source="/Bucket;component/Icon/Icon.png" 
                        Width="128" 
                        Height="128" 
                        Margin="0,0,0,16" />
                    
                    <TextBlock 
                        Text="Bucket" 
                        FontSize="32" 
                        FontWeight="SemiBold" 
                        HorizontalAlignment="Center" />
                        
                    <TextBlock 
                        Text="{Binding BucketVersion, StringFormat='Version {0}'}" 
                        FontSize="16" 
                        HorizontalAlignment="Center" 
                        Opacity="0.8" 
                        Margin="0,5,0,0" />
                    
                    <TextBlock 
                        Text="Windows Image Customizer" 
                        FontSize="18" 
                        HorizontalAlignment="Center" 
                        Margin="0,5,0,0" />
                </StackPanel>

                <!-- Cartes de statut -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- Carte d'état de l'image -->
                    <Border 
                        Grid.Column="0" 
                        Background="White" 
                        CornerRadius="8" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        Margin="0,0,10,0" 
                        Padding="20">
                        <StackPanel>
                            <TextBlock 
                                Text="État de l'image" 
                                FontSize="18" 
                                FontWeight="SemiBold" 
                                Margin="0,0,0,10" />
                            
                            <TextBlock 
                                Text="{Binding ImageMountStatus}" 
                                FontSize="14" 
                                Margin="0,0,0,5" />
                            
                            <TextBlock 
                                Text="{Binding CurrentImageInfo}" 
                                FontSize="12" 
                                TextWrapping="Wrap" 
                                Opacity="0.7" 
                                Margin="0,0,0,15" />
                            
                            <Button 
                                x:Name="BtnSelectImage" 
                                Content="Sélectionner une image"
                                Padding="12,8"
                                Background="#2979FF"
                                Foreground="White"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                    
                    <!-- Carte d'espace disque -->
                    <Border 
                        Grid.Column="1" 
                        Background="White" 
                        CornerRadius="8" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        Margin="10,0,0,0" 
                        Padding="20">
                        <StackPanel>
                            <TextBlock 
                                Text="Espace disque" 
                                FontSize="18" 
                                FontWeight="SemiBold" 
                                Margin="0,0,0,10" />
                            
                            <TextBlock 
                                Text="{Binding DiskSpaceInfo}" 
                                FontSize="14" 
                                Margin="0,0,0,5" />
                            
                            <TextBlock 
                                Text="Répertoire de travail:" 
                                FontSize="12" 
                                Margin="0,10,0,2" 
                                FontWeight="SemiBold" />
                            
                            <TextBlock 
                                Text="{Binding WorkingDirectory}" 
                                FontSize="12" 
                                TextWrapping="Wrap" />
                            
                            <TextBlock 
                                Text="Répertoire de montage:" 
                                FontSize="12" 
                                Margin="0,10,0,2" 
                                FontWeight="SemiBold" />
                            
                            <TextBlock 
                                Text="{Binding MountDirectory}" 
                                FontSize="12" 
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
                
                <!-- Actions rapides -->
                <Border 
                    Background="White" 
                    CornerRadius="8" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    Margin="0,0,0,20" 
                    Padding="20">
                    <StackPanel>
                        <TextBlock 
                            Text="Actions rapides" 
                            FontSize="18" 
                            FontWeight="SemiBold" 
                            Margin="0,0,0,15" />
                        
                        <UniformGrid Rows="2" Columns="3">
                            <Button 
                                x:Name="BtnAppManagement" 
                                Content="Applications"
                                Margin="5"
                                Padding="10"
                                Height="40"
                                Background="#F5F5F5"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            
                            <Button 
                                x:Name="BtnDriverManagement" 
                                Content="Pilotes"
                                Margin="5"
                                Padding="10"
                                Height="40"
                                Background="#F5F5F5"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            
                            <Button 
                                x:Name="BtnCustomization" 
                                Content="Personnalisation"
                                Margin="5"
                                Padding="10"
                                Height="40"
                                Background="#F5F5F5"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            
                            <Button 
                                x:Name="BtnCompletedWIMs" 
                                Content="Images"
                                Margin="5"
                                Padding="10"
                                Height="40"
                                Background="#F5F5F5"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            
                            <Button 
                                x:Name="BtnSettings" 
                                Content="Configuration"
                                Margin="5"
                                Padding="10"
                                Height="40"
                                Background="#F5F5F5"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            
                            <Button 
                                x:Name="BtnHelp" 
                                Content="Aide"
                                Margin="5"
                                Padding="10"
                                Height="40"
                                Background="#F5F5F5"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                </Border>
                
                <!-- Statistiques simples -->
                <Border 
                    Background="White" 
                    CornerRadius="8" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock 
                            Grid.Row="0"
                            Text="Statistiques" 
                            FontSize="18" 
                            FontWeight="SemiBold" 
                            Margin="0,0,0,15" />
                        
                        <UniformGrid Grid.Row="1" Rows="1" Columns="3">
                            <StackPanel Margin="5">
                                <TextBlock 
                                    Text="Images montées" 
                                    FontSize="14" 
                                    Opacity="0.8" 
                                    HorizontalAlignment="Center"/>
                                <TextBlock 
                                    Text="{Binding MountedImagesCount}" 
                                    FontSize="24" 
                                    FontWeight="Bold" 
                                    HorizontalAlignment="Center"
                                    Margin="0,5,0,0" />
                            </StackPanel>
                            
                            <StackPanel Margin="5">
                                <TextBlock 
                                    Text="Pilotes" 
                                    FontSize="14" 
                                    Opacity="0.8" 
                                    HorizontalAlignment="Center"/>
                                <TextBlock 
                                    Text="{Binding InstalledDriversCount}" 
                                    FontSize="24" 
                                    FontWeight="Bold" 
                                    HorizontalAlignment="Center"
                                    Margin="0,5,0,0" />
                            </StackPanel>
                            
                            <StackPanel Margin="5">
                                <TextBlock 
                                    Text="Applications" 
                                    FontSize="14" 
                                    Opacity="0.8" 
                                    HorizontalAlignment="Center"/>
                                <TextBlock 
                                    Text="{Binding SelectedAppsCount}" 
                                    FontSize="24" 
                                    FontWeight="Bold" 
                                    HorizontalAlignment="Center"
                                    Margin="0,5,0,0" />
                            </StackPanel>
                        </UniformGrid>
                    </Grid>
                </Border>
                
                <!-- Pied de page -->
                <TextBlock 
                    Text="Développé par Mickaël CHAVE - © 2025" 
                    FontSize="12" 
                    Opacity="0.6" 
                    HorizontalAlignment="Center" 
                    Margin="0,20,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>