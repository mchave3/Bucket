<Window 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Bucket - Windows Image Customizer"
    Height="720" 
    Width="1280" 
    WindowStartupLocation="CenterScreen"
    Background="#F9F9F9">

    <Window.Resources>
        <!-- Style for main menu buttons -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="5,2" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                SnapsToDevicePixels="True" 
                                CornerRadius="4">
                            <ContentPresenter x:Name="contentPresenter" 
                                              ContentTemplate="{TemplateBinding ContentTemplate}" 
                                              Content="{TemplateBinding Content}" 
                                              ContentStringFormat="{TemplateBinding ContentStringFormat}" 
                                              Focusable="False" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" TargetName="border" Value="#F0F0F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" TargetName="border" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for selected menu buttons -->
        <Style x:Key="SelectedMenuButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#E3F2FD" />
            <Setter Property="Foreground" Value="#1976D2" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0,0,0,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Border Grid.Row="0" Background="#2979FF" Height="40">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <Image Source="/Bucket;component/Icon/Icon.png" Width="20" Height="20" Margin="0,0,10,0" />
                    <TextBlock Text="Bucket" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding BucketVersion, StringFormat=' - v{0}'}" 
                               Foreground="White" 
                               Opacity="0.8" 
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content with navigation on the left -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Navigation menu on the left -->
            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">
                    <!-- Main menu -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,15,0,0">
                        <Button x:Name="NavHome" 
                                Content="Home" 
                                Tag="homePage"
                                Style="{StaticResource MenuButtonStyle}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏠" FontSize="16" Margin="0,0,10,0" />
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>

                        <Button x:Name="NavSelectImage" 
                                Content="Image Selection" 
                                Tag="selectImagePage"
                                Style="{StaticResource MenuButtonStyle}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💿" FontSize="16" Margin="0,0,10,0" />
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>

                        <Button x:Name="NavCustomization" 
                                Content="Customization" 
                                Tag="customizationPage"
                                Style="{StaticResource MenuButtonStyle}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎨" FontSize="16" Margin="0,0,10,0" />
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>

                        <Button x:Name="NavApplications" 
                                Content="Applications" 
                                Tag="applicationsPage"
                                Style="{StaticResource MenuButtonStyle}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📦" FontSize="16" Margin="0,0,10,0" />
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>

                        <Button x:Name="NavDrivers" 
                                Content="Drivers" 
                                Tag="driversPage"
                                Style="{StaticResource MenuButtonStyle}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔌" FontSize="16" Margin="0,0,10,0" />
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>

                        <Button x:Name="NavSettings" 
                                Content="Settings" 
                                Tag="configPage"
                                Style="{StaticResource MenuButtonStyle}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚙️" FontSize="16" Margin="0,0,10,0" />
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </StackPanel>

                    <!-- Bottom element -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,15">
                        <Button x:Name="NavAbout" 
                                Content="About" 
                                Tag="aboutPage"
                                Style="{StaticResource MenuButtonStyle}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ℹ️" FontSize="16" Margin="0,0,10,0" />
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </StackPanel>

                    <!-- Logo and information at the bottom of navigation -->
                    <Border VerticalAlignment="Bottom" Padding="10" Margin="5">
                        <StackPanel>
                            <TextBlock Text="Bucket" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="Windows Image Customizer" FontSize="10" Opacity="0.7" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Main content on the right -->
            <Frame Grid.Column="1" x:Name="RootFrame" NavigationUIVisibility="Hidden" Background="#F9F9F9" />
        </Grid>
    </Grid>
</Window>
