<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="Bucket - Windows Image Customization Tool" 
        Width="1000" 
        Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#EFEFEF">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <!-- Menu sur la gauche -->
        <Border Grid.Column="0" Background="#2B579A">
            <DockPanel>
                <!-- Entête avec logo -->
                <StackPanel DockPanel.Dock="Top" Margin="15">
                    <TextBlock Text="Bucket" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="Windows Image Customization" 
                               FontSize="14" 
                               Margin="0,5,0,0" 
                               Foreground="White"
                               Opacity="0.8"/>
                    <TextBlock x:Name="VersionText" 
                               Text="Version: BucketVer" 
                               FontSize="12" 
                               Margin="0,5,0,0" 
                               Foreground="White"
                               Opacity="0.6"/>
                    <Separator Margin="0,15,0,15" Background="#5074B1" />
                </StackPanel>
                
                <!-- Menu de Navigation -->
                <StackPanel>
                    <Controls:Tile x:Name="DashboardTile"
                                  Margin="10,5"
                                  Background="#1E3A5F" 
                                  Height="60">
                        <TextBlock Text="Tableau de bord" 
                                   FontSize="16" 
                                   Foreground="White"/>
                    </Controls:Tile>
                    
                    <Controls:Tile x:Name="ImageTile"
                                  Margin="10,5"
                                  Background="#3A6EAF" 
                                  Height="60">
                        <TextBlock Text="Gestion des images" 
                                   FontSize="16" 
                                   Foreground="White"/>
                    </Controls:Tile>
                    
                    <Controls:Tile x:Name="CustomizeTile"
                                  Margin="10,5"
                                  Background="#3A6EAF" 
                                  Height="60">
                        <TextBlock Text="Personnalisation" 
                                   FontSize="16" 
                                   Foreground="White"/>
                    </Controls:Tile>
                    
                    <Controls:Tile x:Name="SettingsTile"
                                  Margin="10,5"
                                  Background="#3A6EAF" 
                                  Height="60">
                        <TextBlock Text="Paramètres" 
                                   FontSize="16" 
                                   Foreground="White"/>
                    </Controls:Tile>
                </StackPanel>
            </DockPanel>
        </Border>
        
        <!-- Zone de contenu principale -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Titre de la page -->
            <StackPanel Grid.Row="0">
                <TextBlock x:Name="PageTitle" 
                           Text="Tableau de bord" 
                           FontSize="28" 
                           FontWeight="Light"/>
                <Separator Margin="0,10,0,20" />
            </StackPanel>
            
            <!-- Contenu principal -->
            <Grid Grid.Row="1">
                <TextBlock Text="Bienvenue dans Bucket" 
                           FontSize="22" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
                <TextBlock Text="Sélectionnez une option dans le menu pour commencer" 
                           FontSize="16" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           Margin="0,50,0,0"/>
            </Grid>
        </Grid>
    </Grid>
</Window>