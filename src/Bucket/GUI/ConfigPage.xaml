<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Class="Bucket.GUI.ConfigPage"
    Title="Configuration"
    Background="{ui:ThemeResource ApplicationBackgroundBrush}">

    <ScrollViewer>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- En-tête -->
            <TextBlock 
                Grid.Row="0"
                Text="Configuration de Bucket"
                FontSize="28"
                FontWeight="SemiBold"
                Margin="0,0,0,20" />

            <!-- Contenu principal -->
            <StackPanel Grid.Row="1" Spacing="16">
                <!-- Répertoires de travail -->
                <ui:CardExpander Icon="{ui:SymbolIcon Folder24}" Header="Répertoires de travail">
                    <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox 
                                Grid.Column="0"
                                PlaceholderText="Répertoire de travail principal"
                                Name="TxtWorkingDirectory"
                                Text="{Binding WorkingDirectory}" />
                            <ui:Button 
                                Grid.Column="1"
                                Content="Parcourir"
                                Icon="{ui:SymbolIcon Folder24}"
                                Appearance="Secondary"
                                Margin="10,0,0,0"
                                Name="BtnBrowseWorkingDir" />
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox 
                                Grid.Column="0"
                                PlaceholderText="Répertoire des images montées"
                                Name="TxtMountDirectory"
                                Text="{Binding MountDirectory}" />
                            <ui:Button 
                                Grid.Column="1"
                                Content="Parcourir"
                                Icon="{ui:SymbolIcon Folder24}"
                                Appearance="Secondary"
                                Margin="10,0,0,0"
                                Name="BtnBrowseMountDir" />
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox 
                                Grid.Column="0"
                                PlaceholderText="Répertoire des images finalisées"
                                Name="TxtCompletedWIMsDirectory"
                                Text="{Binding CompletedWIMsDirectory}" />
                            <ui:Button 
                                Grid.Column="1"
                                Content="Parcourir"
                                Icon="{ui:SymbolIcon Folder24}"
                                Appearance="Secondary"
                                Margin="10,0,0,0"
                                Name="BtnBrowseCompletedWIMsDir" />
                        </Grid>
                        
                        <ui:Button 
                            Content="Appliquer les changements"
                            Icon="{ui:SymbolIcon Save24}"
                            Appearance="Primary"
                            HorizontalAlignment="Right"
                            Name="BtnSaveDirectories" />
                    </StackPanel>
                </ui:CardExpander>
                
                <!-- Paramètres de journalisation -->
                <ui:CardExpander Icon="{ui:SymbolIcon TextBulletListLtr24}" Header="Journalisation">
                    <StackPanel Spacing="8">
                        <ui:ToggleSwitch Content="Activer la journalisation détaillée" 
                                       Name="ToggleVerboseLogging" 
                                       IsChecked="False" />
                        <ui:ToggleSwitch Content="Conserver les journaux après fermeture" 
                                       Name="ToggleKeepLogs" 
                                       IsChecked="True" />
                        <ui:ComboBox 
                            PlaceholderText="Niveau de journalisation"
                            Margin="0,8,0,0"
                            Name="CmbLogLevel">
                            <ComboBoxItem Content="Information" IsSelected="True" />
                            <ComboBoxItem Content="Debug" />
                            <ComboBoxItem Content="Verbose" />
                            <ComboBoxItem Content="Warning" />
                            <ComboBoxItem Content="Error" />
                        </ui:ComboBox>
                        
                        <ui:Button 
                            Content="Voir les journaux"
                            Icon="{ui:SymbolIcon Document24}"
                            Appearance="Secondary"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"
                            Name="BtnViewLogs" />
                    </StackPanel>
                </ui:CardExpander>
                
                <!-- Préférences de DISM -->
                <ui:CardExpander Icon="{ui:SymbolIcon ToolboxSolid24}" Header="Options DISM">
                    <StackPanel Spacing="8">
                        <ui:ToggleSwitch Content="Utiliser DISM en ligne de commande (vs. API)" 
                                       Name="ToggleUseDismCLI" 
                                       IsChecked="False" />
                        <ui:ToggleSwitch Content="Mode Verbose pour DISM" 
                                       Name="ToggleDismVerbose" 
                                       IsChecked="False" />
                        <ui:ToggleSwitch Content="Mode sans erreur (ScratchDirectory)" 
                                       Name="ToggleUseScratchDir" 
                                       IsChecked="True" />
                                       
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox 
                                Grid.Column="0"
                                PlaceholderText="Répertoire temporaire (ScratchDirectory)"
                                Name="TxtScratchDirectory"
                                Text="{Binding ScratchDirectory}" />
                            <ui:Button 
                                Grid.Column="1"
                                Content="Parcourir"
                                Icon="{ui:SymbolIcon Folder24}"
                                Appearance="Secondary"
                                Margin="10,0,0,0"
                                Name="BtnBrowseScratchDir" />
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>
                
                <!-- Paramètres d'interface -->
                <ui:CardExpander Icon="{ui:SymbolIcon DesktopPulse24}" Header="Interface utilisateur">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Thème" />
                        <ui:RadioButtons>
                            <ui:RadioButton Content="Clair" GroupName="Theme" Name="RadioThemeLight" />
                            <ui:RadioButton Content="Sombre" GroupName="Theme" Name="RadioThemeDark" />
                            <ui:RadioButton Content="Système" GroupName="Theme" Name="RadioThemeSystem" IsChecked="True" />
                        </ui:RadioButtons>
                        
                        <TextBlock Text="Langue" Margin="0,8,0,0" />
                        <ui:ComboBox 
                            PlaceholderText="Langue de l'interface"
                            Name="CmbLanguage">
                            <ComboBoxItem Content="Français" IsSelected="True" />
                            <ComboBoxItem Content="English" />
                        </ui:ComboBox>
                        
                        <ui:ToggleSwitch Content="Démarrer avec Windows" 
                                       Name="ToggleStartWithWindows" 
                                       IsChecked="False"
                                       Margin="0,8,0,0" />
                        <ui:ToggleSwitch Content="Réduire dans la barre des tâches" 
                                       Name="ToggleMinimizeToTray" 
                                       IsChecked="True" />
                    </StackPanel>
                </ui:CardExpander>
                
                <!-- Réinitialisation -->
                <ui:CardExpander Icon="{ui:SymbolIcon ArrowReset24}" Header="Réinitialisation">
                    <StackPanel Spacing="16">
                        <TextBlock 
                            Text="Réinitialisez les paramètres de Bucket à leurs valeurs par défaut. Cette action ne peut pas être annulée."
                            TextWrapping="Wrap" />
                            
                        <ui:Button 
                            Content="Réinitialiser tous les paramètres"
                            Icon="{ui:SymbolIcon ArrowReset24}"
                            Appearance="Danger"
                            HorizontalAlignment="Right"
                            Name="BtnResetSettings" />
                    </StackPanel>
                </ui:CardExpander>
                
                <!-- Bouton de sauvegarde global -->
                <ui:Button 
                    Content="Enregistrer toutes les modifications"
                    Icon="{ui:SymbolIcon Save24}"
                    Appearance="Success"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0"
                    Padding="20,8"
                    Name="BtnSaveAllSettings" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>