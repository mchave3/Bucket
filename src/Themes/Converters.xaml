<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:common="using:Bucket.Common">

    <!-- Boolean to Visibility Converter -->
    <common:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <!-- Object to Boolean Converter -->
    <common:ObjectToBooleanConverter x:Key="ObjectToBooleanConverter" />

    <!-- Object to Visibility Converter -->
    <common:ObjectToVisibilityConverter x:Key="ObjectToVisibilityConverter" />

    <!-- MS Catalog Converters -->
    <common:SearchModeToVisibilityConverter x:Key="SearchModeToVisibilityConverter" />
    <common:EnumToIntConverter x:Key="EnumToIntConverter" />
    <common:BooleanNegationConverter x:Key="BooleanNegationConverter" />
    <common:ZeroToTrueConverter x:Key="ZeroToTrueConverter" />
    <common:ZeroToVisibleConverter x:Key="ZeroToVisibleConverter" />
    <common:DateFormatConverter x:Key="DateFormatConverter" />
    <common:GreaterThanZeroToBoolConverter x:Key="GreaterThanZeroToBoolConverter" />
    <common:GreaterThanZeroToVisibilityConverter x:Key="GreaterThanZeroToVisibilityConverter" />
    <common:StringFormatConverter x:Key="StringFormatConverter" />

</ResourceDictionary>
